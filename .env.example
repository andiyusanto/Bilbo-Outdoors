# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Optional. If set, the server persists to this Postgres database
# instead of the local server_db.json file (see CLAUDE.md "Database Architecture").
# Use the Supabase "Session pooler" connection string, not "Direct connection" -
# the direct-connection host is IPv6-only on the free tier and will fail to
# connect from networks without IPv6 routing. Get it from: Supabase dashboard ->
# your project -> Connect -> Connection string -> Session pooler.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.MY_PROJECT_REF:MY_PASSWORD@aws-0-MY_REGION.pooler.supabase.com:5432/postgres"
